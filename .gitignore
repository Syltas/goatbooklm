# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/e2e/.auth/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase
supabase/.temp

# Supabase CLI internal state
supabase/.branches

# gstack tooling state
/.gstack/
.gstack/

# Separate prod-build output (never clobbers dev .next)
/.next-build/

# Screenshots (annotation captures, QA artifacts, design references).
# The two mockups under docs/design/ were committed before this rule and stay
# tracked; `.gitignore` only affects files git does not already know about.
*.png
# …except the design handoff bundle: it's a project deliverable, and its HTML
# references these screenshots, so they ship with it rather than being stripped.
!docs/design_handoff_goatbooklm/**/*.png

# E2E screenshot artifacts
/e2e/.artifacts/

# Session transcripts / chat exports (working artifacts, not source)
/chat-exports/

# Audio-Spike-Ausgaben (scripts/audio-spike.ts)
/spike-out/
