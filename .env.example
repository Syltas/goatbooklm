# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# The local Supabase CLI issues new-style API keys (`sb_publishable_...` /
# `sb_secret_...`) instead of the legacy anon/service_role JWTs. Legacy JWT
# keys still work if that's what your project uses — either format is fine
# here, just match what `supabase status` prints for your local stack.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key

# Supabase — server-only. Bypasses Row Level Security, never expose to the client.
# `sb_secret_...` locally (or the legacy `service_role` JWT) — this key
# bypasses RLS entirely, so treat it like any other server secret.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-secret-key

# AI providers — server-only, never expose to the client.
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Ingestion worker (Spec 02): no env var here (Eng-Review L3) — the shared
# secret the `app/api/ingestion-worker/route.ts` Route Handler checks
# against the `x-worker-secret` header lives ONLY in the
# `public.ingestion_worker_config` table, never in an env file or migration.
# Locally it's generated fresh by `supabase/seed.sql` on every
# `supabase db reset`. In production, set it via a manual SQL UPDATE against
# that table post-deploy — see the table's migration
# (`20260719144042_create_ingestion_queue.sql`) header comment for the exact
# statement.

# ElevenLabs (Studio Audio Overview — docs/specs/studio-audio.md)
ELEVENLABS_API_KEY=
# Optional: Voice-IDs der beiden Hosts (Defaults: Adam / Rachel)
ELEVENLABS_VOICE_HOST1=
ELEVENLABS_VOICE_HOST2=
